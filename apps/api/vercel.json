{
  "installCommand": "pnpm install",
  "buildCommand": "npx turbo run build --filter=@simis/api",
  "outputDirectory": "apps/api/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "node_modules/.prisma/**"
    }
  }
}
