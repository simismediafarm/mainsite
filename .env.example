# =============================================================================
# SIMIS — Environment Variables (Example)
# =============================================================================

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# ─── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT]:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?schema=public&pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT]:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres?schema=public"

# ─── UPSTASH REDIS ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://[YOUR-REDIS-URL].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[YOUR-REDIS-TOKEN]"

# ─── QSTASH (Primary Event Bus) ───────────────────────────────────────────────
QSTASH_URL="https://qstash-us-east-1.upstash.io"
QSTASH_TOKEN="[YOUR-QSTASH-TOKEN]"
QSTASH_CURRENT_SIGNING_KEY="sig_..."
QSTASH_NEXT_SIGNING_KEY="sig_..."

# ─── AI PROVIDERS (Free Tier Architecture) ────────────────────────────────────
GEMINI_API_KEY=...
GROK_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-v1-...
DEEPSEEK_API_KEY=sk-...

# ─── LANGCHAIN TRACING ────────────────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="lsv2_pt_..."
LANGSMITH_PROJECT="SIMIS"

# ─── SEARCH / RESEARCH ────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-dev-...

# ─── OBSERVABILITY & SOCIAL ───────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/v10/webhooks/...

# ─── API SERVER ───────────────────────────────────────────────────────────────
PORT=4000
ALLOWED_ORIGIN=http://localhost:3000

# ─── FRONTEND ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_KERNEL_API_URL=http://localhost:4000
