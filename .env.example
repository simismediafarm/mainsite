# =============================================================================
# SIMIS — Environment Variables Template
# Copy this file to .env (for local dev) or configure in your deployment platform.
# =============================================================================

# ─── SUPABASE (REQUIRED) ──────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Service Role Key — server-side ONLY. NEVER expose to browser.
# From Supabase dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── SUPABASE CLIENT (Frontend / Browser) ────────────────────────────────────
# Public anon key — safe for browser use (RLS enforced by Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ─── UPSTASH REDIS (REQUIRED for config cache) ───────────────────────────────
# From Upstash console → your database → REST API
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# ─── AI PROVIDERS ─────────────────────────────────────────────────────────────
# Google Gemini — REQUIRED for LLM reasoning and embeddings
# From https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# OpenAI — optional fallback for embeddings
OPENAI_API_KEY=sk-...

# Groq — optional for high-speed inference
GROQ_API_KEY=gsk_...

# ─── SEARCH / RESEARCH ────────────────────────────────────────────────────────
# Tavily — REQUIRED for reasoning-graph real web search
# From https://app.tavily.com
TAVILY_API_KEY=tvly-...

# ─── PUBLISHING ───────────────────────────────────────────────────────────────
# Vercel deploy hook for edge publishing pipeline
# From Vercel → Project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/YOUR_HOOK_TOKEN/YOUR_GIT_BRANCH

# ─── OBSERVABILITY ────────────────────────────────────────────────────────────
# PostHog — event stream and funnel analytics
# From https://app.posthog.com → Project → Settings → API key
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# OpenTelemetry — trace export endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── API SERVER ───────────────────────────────────────────────────────────────
PORT=4000

# CORS — set to your frontend domain in production
ALLOWED_ORIGIN=http://localhost:3000

# ─── FRONTEND ─────────────────────────────────────────────────────────────────
# URL where the Hono API server is running
NEXT_PUBLIC_KERNEL_API_URL=http://localhost:4000

# ─── OPTIONAL: OPENROUTER ─────────────────────────────────────────────────────
# If using OpenRouter for Claude / Llama fallback
OPENROUTER_API_KEY=sk-or-...
