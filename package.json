{
  "name": "simis-monorepo",
  "private": true,
  "scripts": {
    "postinstall": "pnpm --filter @simis/database exec prisma generate --schema=prisma/schema.prisma && pnpm --filter @simis/api exec prisma generate --schema=prisma/schema.prisma",
    "build": "turbo run build --filter=@simis/api --filter=@simis/web",
    "dev": "turbo run dev --filter=@simis/api --filter=@simis/web",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "audit": "tsx .agent/audit/run_global_audit.ts",
    "audit:ci": "pnpm run audit",
    "clcoa:run": "tsx .agent/cognition/run_clcoa_realtime.ts",
    "clcoa:ground-truth": "pnpm run clcoa:run"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@prisma/config": "^7.8.0",
    "@supabase/supabase-js": "^2.43.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.9.1",
    "fast-glob": "^3.3.3",
    "tsx": "^4.22.4",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "pnpm": {
    "overrides": {
      "uuid": "^9.0.1",
      "typescript": "^5.4.0",
      "ioredis": "^5.11.0"
    }
  }
}
